   "source": [
    "# Two timestamp formats co-exist in the raw data:\n",
    "#   - ISO-8601 with Z suffix  → \"2026-05-24T07:56:29Z\"\n",
    "#   - Plain space-separated   → \"2026-05-06 21:49:19\"\n",
    "\n",
    "df_raw = pd.read_csv(DATA_PATH)\n",
    "# Two timestamp formats co-exist: ISO-8601 with Z suffix and plain space-separated\n",
    "df_raw['timestamp'] = pd.to_datetime(df_raw['timestamp'], format='mixed', utc=True)\n",
    "\n",
    "print(f\"Raw dataset shape  : {df_raw.shape}\")\n",
    "print(f\"Unique tx_ids      : {df_raw['transaction_id'].nunique():,}\")\n",
    "\n",
    "# ── Identify duplicates ────────────────────────────────────────────────────────\n",
    "dup_mask   = df_raw.duplicated('transaction_id', keep=False)\n",
    "n_dup_rows = dup_mask.sum()\n",
    "n_dup_ids  = df_raw.loc[dup_mask, 'transaction_id'].nunique()\n",
    "\n",
    "# Time difference between each duplicate pair\n",
    "dups = df_raw[dup_mask].copy().sort_values(['transaction_id', 'timestamp'])\n",
    "dups['_time_diff_sec'] = dups.groupby('transaction_id')['timestamp'].diff().dt.total_seconds()\n",
    "td = dups['_time_diff_sec'].dropna()\n",
    "\n",
    "print(f\"\\n── Duplicate Analysis ────────────────────────────────────────\")\n",
    "print(f\"  Duplicate rows found               : {n_dup_rows:,}\")\n",
    "print(f\"  Unique duplicate transaction_ids   : {n_dup_ids:,}\")\n",
    "print(f\"  Time gap — min / median / max (s)  : {td.min():.0f}s / {td.median():.0f}s / {td.max():.0f}s\")\n",
    "print(f\"  All duplicates within 1 minute     : {(td < 60).all()}\")\n",
    "\n",
    "# ── Remove duplicates: keep first occurrence ───────────────────────────────────\n",
    "df = (df_raw\n",
    "      .sort_values('timestamp')\n",
    "      .drop_duplicates('transaction_id', keep='first')\n",
    "      .reset_index(drop=True))\n",
    "\n",
    "print(f\"\\n── After Deduplication ───────────────────────────────────────\")\n",
    "print(f\"  Rows removed                       : {len(df_raw) - len(df):,}\")\n",
    "print(f\"  Clean dataset shape                : {df.shape}\")\n",
    "print(f\"  Fraud rate (raw)                   : {df_raw['is_fraud'].mean():.4f}\")\n",
    "print(f\"  Fraud rate (clean)                 : {df['is_fraud'].mean():.4f}\")\n"
   ]
